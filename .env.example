# ===== LOCOAPI 환경변수 템플릿 =====
# 이 파일을 복사하여 .env로 이름 변경 후 실제 값을 입력하세요.
# cp .env.example .env

# ===== 채팅 암호화 =====
CHAT_ENCRYPTION_ENABLED=true
CHAT_SALT=your_chat_salt_here
SEARCH_SALT=your_search_salt_here
REPORTED_MESSAGE_RETENTION_DAYS=1095

# ===== KMS 암호화 =====
ENABLE_KMS=true
ENABLE_ENCRYPTION=true
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-northeast-2
KMS_KEY_ID=your_kms_key_id
KMS_CACHE_MAX_SIZE=100
KMS_CACHE_EXPIRY=1800000

# AES-256 폴백 키 (KMS 실패 시)
ENCRYPTION_SECRET=your_aes256_encryption_secret_32chars
ENCRYPTION_KEY=your_legacy_encryption_key

# ===== MongoDB =====
MONGO_URI=mongodb://user:password@host/dbname

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
ENABLE_CACHE=true
REDIS_CONNECT_TIMEOUT=3000

# ===== 서버 설정 =====
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ===== JWT =====
JWT_SECRET=your_jwt_secret
REFRESH_SECRET=your_refresh_secret

# ===== 세션 =====
SESSION_SECRET=your_session_secret

# ===== URL / CORS =====
BASE_URL_FRONT=http://localhost:5173
FRONTEND_URL=http://localhost:5173
FRONTEND_URL_ALT=http://192.168.x.x:5173

# ===== 소셜 로그인 (카카오) =====
KAKAO_NATIVE_APP_KEY=your_kakao_native_key
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_JS_KEY=your_kakao_js_key
KAKAO_ADMIN_KEY=your_kakao_admin_key
KAKAO_REDIRECT_URI=http://localhost:5173/auth/callback

# ===== 소셜 로그인 (네이버) =====
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:5173/auth/naver/callback

# ===== 포트원 본인인증 =====
PORTONE_API_SECRET=your_portone_api_secret
PORTONE_STORE_ID=your_portone_store_id

# ===== API 키 =====
RIOT_API_KEY=your_riot_api_key

# ===== 알림 =====
DISCORD_WEBHOOK_URL=your_discord_webhook_url
